# ============================================================
# VouchRank — environment variables
# Copy to `.env` and fill in. Only VITE_* vars reach the browser.
# ============================================================

# ---- Supabase (frontend) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the publishable key (sb_publishable_...). NEVER put the service_role key here.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ============================================================
# Server-side only (Edge Functions / Supabase secrets).
# Set with: supabase secrets set KEY=value   — do NOT prefix with VITE_.
# ============================================================

# Supabase service role (Edge Functions only)
SUPABASE_SERVICE_ROLE_KEY=

# Secret used to HMAC-sign the Google OAuth `state` param (recommended).
# If unset, the service-role key is used as the signing key.
OAUTH_STATE_SECRET=
# Shared secret for trusted internal/cron callers of service functions
# (run-aio-audit, sync-google-reviews). Sent as the `x-internal-secret` header
# by scheduled jobs. Leave unset until you wire up cron.
FUNCTION_INTERNAL_SECRET=

# ---- Stripe (billing) ----
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_AGENCY=price_xxx          # $299/mo White-Label Agency
STRIPE_PRICE_AGENCY_PRO=price_xxx      # $499/mo Agency Pro

# ---- Google Business Profile (OAuth + Reviews API) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-PROJECT.functions.supabase.co/google-oauth-callback

# ---- AIO engine (LLM providers) ----
GEMINI_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ---- Review-request delivery ----
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=          # A2P 10DLC-registered messaging service

# ---- App ----
APP_BASE_URL=https://app.vouchrank.com
